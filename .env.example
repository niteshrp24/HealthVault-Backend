# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_NAME=healthvault
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── S3 / MinIO ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_STORAGE_BUCKET_NAME=healthvault-reports
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_ENDPOINT_URL=

# Signed URL TTLs (seconds)
SIGNED_URL_EXPIRY_SECONDS=60
DOWNLOAD_URL_EXPIRY_SECONDS=300

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# WhatsApp sender — use Twilio sandbox in dev: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155236666
TWILIO_SMS_FROM=+1xxxxxxxxxx

# ─── ZeptoMail ────────────────────────────────────────────────────────────────
ZEPTO_API_KEY=your_zepto_api_key
ZEPTO_FROM_EMAIL=noreply@yourdomain.com
ZEPTO_FROM_NAME=HealthVault
